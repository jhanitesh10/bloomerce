DATABASE_URL=sqlite:///./bloomerce_local.db
SEED_MOCK_DATA=false

# Google Drive Configuration
GOOGLE_DRIVE_COMPANY_NAME=bloomerce
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_folder_id_here
GOOGLE_DRIVE_CREDENTIALS='{}'

# CORS Configuration
# Comma-separated list of allowed origins. 
# Defaults to localhost and https://bloomerce.vercel.app if empty.
ALLOWED_ORIGINS=http://localhost:5173,https://bloomerce.vercel.app

# AI Content Catalyst Configuration
AI_PROVIDER=litellm # Options: gemini, openai
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
